# Copy to .env and fill in. NEVER commit the real .env.

# ---- LLM extractor (OpenAI is our chosen provider — hackathon credits) ----
OPENAI_API_KEY=
# Model to use — set to whatever your credits cover (e.g. gpt-4o, gpt-4.1, o4-mini).
LLM_MODEL=gpt-4o
# Force a provider: openai | anthropic | heuristic. Leave blank to auto-detect by key.
LLM_PROVIDER=
# Alternative provider (optional):
ANTHROPIC_API_KEY=

# ---- Storage ----
DATABASE_URL=sqlite:///./tender.db

# ---- Auth (invite-only) ----
# Secret that signs session tokens. Generate a strong one for any real deployment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Left blank, the code falls back to an insecure dev default (local-only).
AUTH_SECRET=

# ---- Google sign-in (optional) ----
# The OAuth 2.0 Web client ID from Google Cloud Console (APIs & Services → Credentials).
# Google ID tokens must be issued for this client id. Left blank, POST /auth/google 503s
# and the frontend hides the Google button (email/password still works). The SAME value
# goes in the frontend as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
# A first-time Google email auto-creates an account (the onboarding path for teammates).
# Set to 0 to keep it strictly invite-only — then only emails that already have an
# account can sign in with Google. Default: on when GOOGLE_CLIENT_ID is set.
GOOGLE_AUTO_PROVISION=1
