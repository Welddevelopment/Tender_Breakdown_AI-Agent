# Bidframe frontend env — copy to .env.local and fill in to talk to the live backend.
# Leave everything unset to run entirely on mock data (the demo-safe default).

# Base URL of the backend API.
#   Local backend:  http://localhost:8000  (run: cd backend && uvicorn app.main:app --reload)
#   Deployed (Render): https://bidframe-api.onrender.com  (see backend/DEPLOY.md)
# When unset, the UI uses mock data and the upload flow is a wireframe (no real parsing).
# When set, the upload flow uploads the PDF and loads the real extracted requirements,
# and decision (approve/edit/flag) changes are persisted via PATCH.
NEXT_PUBLIC_API_BASE_URL=

# Google sign-in (optional). The OAuth 2.0 Web client ID from Google Cloud Console —
# the SAME value the backend verifies against (GOOGLE_CLIENT_ID). Set it to show the
# "Sign in with Google" button on /login; unset, the button is hidden and email/password
# still works. Add your deployment's origin to the client's Authorized JavaScript origins.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cal.com booking link behind every "Book a demo" CTA. Defaults to Joel's live
# Cal.com page, so the deployed CTA works with this unset; set it to move the
# scheduler without a code change.
# NOTE: configure that Cal.com event's "Redirect on booking" (successRedirectUrl)
# to point at <site>/thank-you, so a completed booking returns the visitor to
# Bidframe instead of stranding them on Cal.com.
#NEXT_PUBLIC_BOOKING_URL=
